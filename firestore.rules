rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow write: if hasRole('admin');
    }

    // Settings collection
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin');
    }

    // Investors collection
    match /investors/{investorId} {
      allow read: if isSignedIn() && (hasRole('admin') || hasRole('investor'));
      allow write: if hasRole('admin');
    }

    // Daily Entries collection
    match /daily_entries/{entryId} {
      allow read: if isSignedIn();
      allow create: if hasRole('operator') || hasRole('admin');
      allow update: if hasRole('admin');
      allow delete: if hasRole('admin');
    }
  }
}
